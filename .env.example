# ═══════════════════════════════════════════════════════════════════════════
# BTC/USD Trading Bot — 環境變數完整範本
# ═══════════════════════════════════════════════════════════════════════════
# 本機：cp .env.example .env → 填值 → python main.py 自動載入
# Zeabur：在 Service → Variables 頁面逐個新增（只需設有值的項目）
# ═══════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════
# 🔴 必填 — 沒設系統起不來
# ═══════════════════════════════════════════════

# ── Alpaca Trading ──────────────────────────────
# Paper 與 Live 是兩組不同金鑰，不可混用：
#   Paper: https://app.alpaca.markets/paper/dashboard/overview  (金鑰前綴 PK...)
#   Live : https://app.alpaca.markets/live/dashboard/overview   (金鑰前綴 AK...)
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic Claude API ────────────────────────
# https://console.anthropic.com/settings/keys
# Anthropic SDK 會自動讀取 ANTHROPIC_API_KEY，名稱不可改
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram Bot ────────────────────────────────
# 建立 Bot：@BotFather → /newbot → 拿 token
# 取 Chat ID：發訊息給 @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=1234567890


# ═══════════════════════════════════════════════
# 🟡 建議填 — 有預設但雲端部署應明確
# ═══════════════════════════════════════════════

# true = Paper Trading（強烈建議先跑 2 週）/ false = Live Trading
ALPACA_PAPER_MODE=true

# Zeabur 必須搭配 Volume 掛載：/app/data（SQLite）+ /app/config（yaml）
DB_PATH=/app/data/trading.db
CONFIG_DIR=/app/config

# DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# Telegram 時間顯示時區。UTC 或 Asia/Taipei、America/New_York 等
TZ=UTC


# ═══════════════════════════════════════════════
# 🟢 選填 — 預設值夠用，排障 / 調校時才改
# ═══════════════════════════════════════════════

# ── WebSocket 連線行為 ──────────────────────────
# WS 啟動前等待秒數（Alpaca 釋放舊 session 需 60-180 秒）
WS_STARTUP_DELAY=180

# 連線上限最大重試次數，超過後自動降級為 REST polling（不 exit）
WS_MAX_CONN_LIMIT_RETRIES=10

# Session 協調 lockfile（建議放 Volume 內跨重啟保留）
WS_LOCKFILE_PATH=/app/data/ws_session.lock

# 緊急逃生：true = 完全跳過 WebSocket 走 REST 輪詢模式
# 撞連線上限 / 另一實例佔用時臨時啟用
WS_DISABLE=false

# ── 熔斷器（Circuit Breaker）──────────────────
# 連虧幾次觸發熔斷
CB_MAX_LOSSES=3

# OPEN 狀態暫停小時數（到期自動 → HALF 試單模式）
CB_PAUSE_HOURS=4

# 啟動時強制清熔斷器狀態（卡住時設 true，重啟一次後改回 false）
RESET_CIRCUIT_BREAKER=false

# ── 通知深連結 ───────────────────────────────
# 不設則依 ALPACA_PAPER_MODE 自動推導 /paper 或 /live
# ALPACA_DASHBOARD_URL=https://app.alpaca.markets/paper/dashboard/overview
